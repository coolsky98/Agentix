{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/llms.txt",     "destination": "/api" },
    { "source": "/openapi.json", "destination": "/api" },
    { "source": "/status",       "destination": "/api" },
    { "source": "/files",        "destination": "/api" },
    { "source": "/files/(.*)",   "destination": "/api" },
    { "source": "/repo",         "destination": "/api" },
    { "source": "/repo/(.*)",    "destination": "/api" },
    { "source": "/repos",        "destination": "/api" },
    { "source": "/repos/(.*)",   "destination": "/api" }
  ]
}
