{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/status",     "destination": "/api" },
    { "source": "/files",      "destination": "/api" },
    { "source": "/files/(.*)", "destination": "/api" },
    { "source": "/repo",       "destination": "/api" },
    { "source": "/repo/(.*)",  "destination": "/api" }
  ]
}
